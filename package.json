{
    "name": "@woby/wui",
    "version": "1.0.35",
    "publishConfig": {
        "access": "public"
    },
    "description": "A powerful tooltip and menu component library for voby.",
    "main": "./dist/index.es.js",
    "module": "./dist/index.es.js",
    "browser": "./dist/index.es.js",
    "types": "./dist/types/index.d.ts",
    "style": "./dist/wui.css",
    "exports": {
        ".": {
            "import": "./dist/index.es.js",
            "require": "./dist/index.es.js",
            "types": "./dist/types/index.d.ts"
        },
        "./dist/wui.css": "./dist/wui.css"
    },
    "scripts": {
        "dev": "vite",
        "git": "git add . && git commit -m \"Bump version\" && git push",
        "bump": "pnpm version patch --no-git-tag-version",
        "npmjs": "pnpm publish",
        "release": "run-s -c git bump npmjs",
        "declaration": "tsc --build --force --declaration --emitDeclarationOnly --declarationMap --verbose --noEmitOnError false || echo 'TypeScript declaration completed with errors'",
        "declaration:watch": "tsc --build --force --declaration --emitDeclarationOnly --declarationMap  --verbose --watch",
        "watch": "run-p build:watch",
        "build:watch": "tsc --watch",
        "build": "vite build",
        "test": "vitest run",
        "test:watch": "vitest watch"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/axe-me/wui.git"
    },
    "keywords": [
        "voby",
        "tooltip",
        "menu",
        "context-menu",
        "dropdown",
        "ui"
    ],
    "author": "axe-me",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/axe-me/wui/issues"
    },
    "homepage": "https://github.com/axe-me/wui#readme",
    "dependencies": {
        "@woby/use": "workspace:^",
        "woby": "^1.58.40"
    },
    "devDependencies": {
        "@types/node": "^25.9.1",
        "npm-run-all": "^4.1.5",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.7"
    }
}
